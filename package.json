{
  "name": "my-pet",
  "version": "0.1.0",
  "private": true,
  "description": "Vue 3 микрофронтенды на Module Federation, песочница",
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:full": "npm run build:mfe && concurrently -n dash,prof,bill,shell -c blue,magenta,yellow,cyan \"npm run preview -w @platform/dashboard-mfe\" \"npm run preview -w @platform/profile-mfe\" \"npm run preview -w @platform/billing-mfe\" \"npm run dev -w @platform/shell-app\"",
    "build:mfe": "turbo run build --filter=@platform/dashboard-mfe --filter=@platform/profile-mfe --filter=@platform/billing-mfe",
    "dev:shell": "npm run dev -w @platform/shell-app",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "test": "turbo run test",
    "storybook": "npm run storybook -w @platform/ui-kit"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@platform/eslint-config": "*",
    "@platform/ts-config": "*",
    "@types/node": "^22.10.5",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.7.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.1.10"
  }
}
